{
  "name": "hacs-vision-panel",
  "version": "2.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "postbuild": "node -e \"const fs=require('fs');const v=require('./package.json').version;let h=fs.readFileSync('www/index.html','utf8');h=h.replace(/__VERSION__/g,v);fs.writeFileSync('../custom_components/hacs_vision/frontend/index.html',h)\""
  },
  "dependencies": {
    "dompurify": "^3.4.8",
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "rollup": "^4.0.0"
  }
}
