{
  "name": "hacs-vision-panel",
  "version": "6.4.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "postbuild": "node -e \"const fs=require('fs'),crypto=require('crypto');const hash=crypto.createHash('md5').update(fs.readFileSync('../custom_components/hacs_vision/frontend/panel.js')).digest('hex').slice(0,10);let h=fs.readFileSync('www/index.html','utf8');h=h.replace(/__VERSION__/g,hash);fs.writeFileSync('../custom_components/hacs_vision/frontend/index.html',h);fs.writeFileSync('../custom_components/hacs_vision/frontend/build.json',JSON.stringify({hash:hash}));console.log('Cache hash: '+hash);\""
  },
  "dependencies": {
    "dompurify": "^3.4.8",
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "rollup": "^4.0.0"
  }
}
